# Copy to .env and fill in your values
# Then: set -a && source .env && set +a

ANTHROPIC_API_KEY=sk-ant-...
SWITCH_HOST=192.168.1.1       # IP or hostname of your Cumulus switch
SWITCH_USER=cumulus           # NVUE API user (default: cumulus)
SWITCH_PASS=your_password
NVUE_PORT=8765                # NVUE REST API port (default: 8765)
